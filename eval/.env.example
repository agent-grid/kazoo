# OpenAI API key for the Realtime adapter (and optionally hosted ASR).
OPENAI_API_KEY=

# Google AI Studio API key for the Gemini Live adapter (agents/gemini-live.ts).
# Get one at https://aistudio.google.com/apikey. The adapter pins its own
# model id (defaults to gemini-3.1-flash-live-preview); override via
# VOICE_EVAL_GEMINI_MODEL if you want a different live-capable model.
GEMINI_API_KEY=

# xAI API key for the Grok Voice Realtime adapter (agents/grok-voice.ts).
# Get one at https://console.x.ai. Override the model with VOICE_EVAL_GROK_MODEL
# (default: grok-voice-think-fast-1.0 — xAI's flagship "thinking" voice model).
XAI_API_KEY=

# A/B benchmark switch for scenarios/http-json (see scripts/benchmark-http-json.ts).
# When set to "1", the openai-realtime agent exposes an additional `http_json` tool
# (fetch URL → parsed JSON, optional dot path) and its instructions include a
# Tools.md-style entry telling the model when to use it instead of bash+curl.
# Unset / "0" = baseline (bash-only). The benchmark runner toggles this per-run.
VOICE_EVAL_HTTP_JSON=0
