# Kazoo runtime configuration. Copy to `.env` and fill in.
# Loaded via Bun's native dotenv support — no `dotenv` package required.

# ──────────────────────────────────────────────────────────────────────────
# Required — the two providers Kazoo wires together.
# ──────────────────────────────────────────────────────────────────────────

# OpenAI Realtime (narrator). Always API-key based.
OPENAI_API_KEY=

# Claude executor — accepts EITHER of the following, in this priority order:
#   1. CLAUDE_CODE_OAUTH_TOKEN  — Claude subscription credential (preferred;
#      same token the `claude` CLI uses after `claude login`).
#   2. ANTHROPIC_API_KEY        — pay-as-you-go Anthropic API key.
# Set one. The executor PR will pick whichever is present and pass it
# through to `@anthropic-ai/claude-agent-sdk`. (Phase 0 doesn't read either
# of these — the audio loopback only touches OPENAI_API_KEY.)
CLAUDE_CODE_OAUTH_TOKEN=
ANTHROPIC_API_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Realtime (narrator). All optional — defaults are sensible.
# ──────────────────────────────────────────────────────────────────────────
# OpenAI Realtime GA model alias. `gpt-realtime-mini` is also valid.
KAZOO_REALTIME_MODEL=gpt-realtime
# Voice. Default `alloy` is always GA-available; other voices may require
# verification on the account. If the server rejects the requested voice on
# session.update (voice-not-available error), the session falls back to
# `alloy` once and continues — see `isVoiceUnavailable` in
# src/realtime/session.ts.
KAZOO_REALTIME_VOICE=alloy
# Playback speed override. 0.25–1.5. Omit / blank to use the API default (1.0).
KAZOO_REALTIME_SPEED=

# ──────────────────────────────────────────────────────────────────────────
# Executor (Claude Agent SDK). Optional overrides.
# ──────────────────────────────────────────────────────────────────────────
KAZOO_EXECUTOR_MODEL=claude-sonnet-4-6
# Bumpable to claude-opus-4-8 for harder tasks.

# ──────────────────────────────────────────────────────────────────────────
# Memory + logging.
# ──────────────────────────────────────────────────────────────────────────
# Per-user voice/narration preferences. Survives across project clones.
# Default: ~/.kazoo/voice-memory.md
KAZOO_USER_MEMORY_PATH=
# Repo-local project facts (parallel to CLAUDE.md). Loaded if present.
KAZOO_PROJECT_MEMORY_PATH=./KAZOO.md
# ND-JSON log file. Ink owns stdout, so all logs go to a file.
KAZOO_LOG_FILE=./.kazoo/log.ndjson
KAZOO_LOG_LEVEL=info
