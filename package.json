{
  "name": "kazoo",
  "version": "0.0.0",
  "description": "Voice-native coding agent in a terminal-styled Electron surface. Talk to it; hear it think out loud.",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "ELECTRON_DISABLE_SANDBOX=1 electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "package": "electron-vite build && electron-builder",
    "package:dir": "electron-vite build && electron-builder --dir",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.158",
    "dotenv": "^16.4.5",
    "pino": "^10.3.1",
    "shell-quote": "^1.8.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-linux-x64": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-linux-arm64": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-linux-x64-musl": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-linux-arm64-musl": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "^0.3.158",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "^0.3.158"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/node": "^20.19.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.0",
    "@types/shell-quote": "^1.7.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^6.0.3",
    "vite": "^5.4.20",
    "vitest": "^2.1.9"
  }
}
