{
  "name": "kazoo",
  "version": "0.0.0",
  "description": "Voice-native TUI coding agent. Talk to it; hear it think out loud.",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "audio-check": "bun run scripts/audio-loopback.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.158",
    "ink": "^7.0.5",
    "pino": "^10.3.1",
    "react": "^19.2.0",
    "shell-quote": "^1.8.4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/react": "^19.2.15",
    "@types/shell-quote": "^1.7.5",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  }
}
